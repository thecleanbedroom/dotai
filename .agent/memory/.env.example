# Project Memory System — Environment Configuration
# Copy this file to .env and fill in your values.

# Required for build/rebuild mode
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Models for two-pass build:
#   Extract model (free/cheap) — processes commit batches
#   Extract fallback — used when primary hits output cap
#   Reasoning model (smart) — creates links and refines memories
# Any model with 32K+ context and JSON output support will work.
#
# Verified models on OpenRouter (as of 2026-03):
#   nvidia/nemotron-3-super-120b-a12b:free (262K context, free — best for extraction)
#   google/gemini-2.5-flash-lite      (1M context, cheap — good extraction fallback)
#   google/gemini-2.5-flash           (1M context, reasoning — good for synthesis)
#   google/gemini-3.1-pro-preview     (1M context, best quality reasoning)
#   google/gemini-2.5-pro             (1M context, best quality reasoning)
#   anthropic/claude-sonnet-4.6       (1M context, strong reasoning)
# MEMORY_EXTRACT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# MEMORY_EXTRACT_FALLBACK_MODEL=google/gemini-2.5-flash-lite
# MEMORY_REASONING_MODEL=google/gemini-3.1-pro-preview

# Optional: override the API endpoint
# MEMORY_BUILD_API_URL=https://openrouter.ai/api/v1/chat/completions

# Optional: max commits to process (newest first). 0 = entire git history.
# Default: 0 (all commits)
# MEMORY_COMMIT_LIMIT=0

# Optional: token budget per LLM batch. Lower = more batches, more even sizing.
# Commits are packed into a batch until the next one would exceed this budget.
# A single commit that exceeds the budget gets its own batch (never dropped).
# Default: 100000
# MEMORY_BATCH_TOKEN_BUDGET=100000

# Optional: max commits per LLM batch. Fewer commits = deeper analysis per commit.
# Works alongside token budget — batch splits on whichever limit is hit first.
# A single oversized commit always gets its own batch (never dropped).
# Default: 20
# MEMORY_BATCH_MAX_COMMITS=20
