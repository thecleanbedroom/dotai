# Project Memory System — Environment Configuration
# Copy this file to .env and fill in your values.

# Required for build/rebuild mode
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default model (anthropic/claude-sonnet-4.6)
# Budget and output limits are auto-tuned from the model's context window.
# Any model with 32K+ context and JSON output support will work.
#
# Verified models on OpenRouter (as of 2026-03):
#   anthropic/claude-sonnet-4.6       (default — 1M context, strong reasoning)
#   google/gemini-2.5-pro             (1M context, best quality)
#   google/gemini-2.5-flash           (1M context, fast + cheap)
#   openai/gpt-5.4                    (1M context)
#   deepseek/deepseek-v3.2            (164K context, cheap)
#   meta-llama/llama-4-maverick       (1M context, open-source)
# MEMORY_BUILD_MODEL=anthropic/claude-sonnet-4.6

# Optional: override the API endpoint
# MEMORY_BUILD_API_URL=https://openrouter.ai/api/v1/chat/completions

# Optional: max commits to process (newest first). 0 = entire git history.
# Default: 0 (all commits)
# MEMORY_COMMIT_LIMIT=200

# Optional: token budget per LLM batch. Lower = more batches, more even sizing.
# Commits are packed into a batch until the next one would exceed this budget.
# A single commit that exceeds the budget gets its own batch (never dropped).
# Default: 10000
# MEMORY_BATCH_TOKEN_BUDGET=5000

# Optional: max commits per LLM batch. Fewer commits = deeper analysis per commit.
# Works alongside token budget — batch splits on whichever limit is hit first.
# A single oversized commit always gets its own batch (never dropped).
# Default: 10
# MEMORY_BATCH_MAX_COMMITS=20
