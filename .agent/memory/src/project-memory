#!/usr/bin/env python3
"""Project Memory System entrypoint."""

import os as _os, sys as _sys

# Ensure parent directory (memory/) is on path so 'src' package is importable
_sys.path.insert(0, _os.path.join(_os.path.dirname(_os.path.abspath(__file__)), ".."))

# Suppress __pycache__ directories
_sys.dont_write_bytecode = True

import argparse
import json

from src.deps import DependencyChecker
from src.db import Database
from src.stores import MemoryStore, LinkStore, BuildMetaStore
from src.git import GitLogParser
from src.llm import LLMClient
from src.openrouter import OpenRouterAPI
from src.build import BuildAgent
from src.inspector import Inspector
from src.server import McpServer
from src.models import BuildMetaEntry


def create_components(db_path=None, repo_path=None, project_root=None):
    """Create and wire all components."""
    from src.config import Config
    config = Config.from_env()
    openrouter = OpenRouterAPI(config)
    db = Database(db_path)
    db.init_schema()
    memory_store = MemoryStore(db)
    link_store = LinkStore(db)
    build_meta_store = BuildMetaStore(db)
    git_parser = GitLogParser(repo_path or project_root)
    extract_llm = LLMClient(config, model=config.MEMORY_EXTRACT_MODEL, openrouter=openrouter)
    extract_fallback_llm = LLMClient(config, model=config.MEMORY_EXTRACT_FALLBACK_MODEL, openrouter=openrouter)
    reasoning_llm = LLMClient(config, model=config.MEMORY_REASONING_MODEL, openrouter=openrouter)
    inspector = Inspector(db, memory_store, link_store, build_meta_store)
    return (db, memory_store, link_store, build_meta_store,
            git_parser, extract_llm, extract_fallback_llm, reasoning_llm,
            openrouter, inspector)


def main():
    parser = argparse.ArgumentParser(
        description="Project Memory System — persistent project knowledge from git history",
    )
    subparsers = parser.add_subparsers(dest="command", help="Command to run")

    # serve
    serve_parser = subparsers.add_parser("serve", help="Start MCP server (stdio)")

    # build (incremental, resumable)
    build_parser = subparsers.add_parser("build", help="Incremental build (resumes from last build)")
    build_parser.add_argument("--limit", type=int, default=None,
                              help="Max number of commits to process")
    build_parser.add_argument("-y", "--yes", action="store_true",
                              help="Skip cost confirmation prompt")
    build_parser.add_argument("--db", type=str, default=None,
                              help="Path to database file")
    build_parser.add_argument("--repo", type=str, default=None,
                              help="Path to git repository")

    # rebuild (full wipe + reprocess)
    rebuild_parser = subparsers.add_parser("rebuild", help="Full rebuild from scratch")
    rebuild_parser.add_argument("--limit", type=int, default=None,
                                help="Max number of commits to process")
    rebuild_parser.add_argument("-y", "--yes", action="store_true",
                                help="Skip cost confirmation prompt")
    rebuild_parser.add_argument("--db", type=str, default=None,
                                help="Path to database file")
    rebuild_parser.add_argument("--repo", type=str, default=None,
                                help="Path to git repository")

    # inspect
    inspect_parser = subparsers.add_parser("inspect", help="Debug/inspect raw data")
    inspect_parser.add_argument("query", nargs="*", default=["help"],
                                help="Inspect command (tables, memories, memory <id>, etc.)")
    inspect_parser.add_argument("--db", type=str, default=None,
                                help="Path to database file")

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        _sys.exit(1)

    # Only check deps that are needed for this command
    if args.command == "serve":
        DependencyChecker.check()
    elif args.command in ("build", "rebuild"):
        DependencyChecker.check(skip=("mcp",), require_api_key=True)
    else:
        DependencyChecker.check(skip=("mcp", "requests"))


    if args.command == "serve":
        # Serve mode: components created lazily from MCP roots
        def component_factory(project_root=None):
            comps = create_components(
                repo_path=project_root,
                project_root=project_root,
            )
            (db, mem_store, lnk_store, bm_store,
             git_par, ext_llm, ext_fb_llm, reas_llm, orouter, insp) = comps
            agent = BuildAgent(
                db, mem_store, lnk_store, bm_store,
                git_par, ext_llm,
                extract_fallback_llm=ext_fb_llm,
                reasoning_llm=reas_llm,
                openrouter=orouter,
            )
            return {
                "db": db,
                "memory_store": mem_store,
                "link_store": lnk_store,
                "build_meta_store": bm_store,
                "inspector": insp,
                "build_agent": agent,
            }

        server = McpServer(component_factory)
        try:
            server.run()
        finally:
            server.cleanup()

    else:
        # CLI commands: use explicit paths
        db_path = getattr(args, "db", None)
        repo_path = getattr(args, "repo", None)
        project_root = getattr(args, "project_root", None)
        (db, memory_store, link_store, build_meta_store,
         git_parser, extract_llm, extract_fallback_llm,
         reasoning_llm, openrouter, inspector) = create_components(
            db_path, repo_path, project_root,
        )
        try:
            if args.command == "build":
                agent = BuildAgent(
                    db, memory_store, link_store, build_meta_store,
                    git_parser, extract_llm,
                    extract_fallback_llm=extract_fallback_llm,
                    reasoning_llm=reasoning_llm,
                    openrouter=openrouter,
                )
                result = agent.build(limit=args.limit, auto_confirm=args.yes)
                print(json.dumps(result, indent=2))

            elif args.command == "rebuild":
                agent = BuildAgent(
                    db, memory_store, link_store, build_meta_store,
                    git_parser, extract_llm,
                    extract_fallback_llm=extract_fallback_llm,
                    reasoning_llm=reasoning_llm,
                    openrouter=openrouter,
                )
                result = agent.rebuild(limit=args.limit, auto_confirm=args.yes)
                print(json.dumps(result, indent=2))

            elif args.command == "inspect":
                query_str = " ".join(args.query)
                print(inspector.inspect(query_str))
        finally:
            db.close()


if __name__ == "__main__":
    main()
