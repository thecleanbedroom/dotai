#!/usr/bin/env bash
# Setup the project memory system — creates a local venv, installs dependencies,
# and ensures .env exists.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MEMORY_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV_DIR="$MEMORY_DIR/.venv"

# Create venv if missing
if [ -d "$VENV_DIR" ]; then
    echo "Venv already exists at $VENV_DIR"
else
    echo "Creating venv..."
    python3 -m venv "$VENV_DIR"
fi

# Install dependencies
echo "Installing dependencies..."
"$VENV_DIR/bin/pip" install -q -r "$SCRIPT_DIR/requirements.txt"

# Create .env from example if missing
if [ ! -f "$MEMORY_DIR/.env" ]; then
    cp "$MEMORY_DIR/.env.example" "$MEMORY_DIR/.env"
    echo ""
    echo "Created .env from .env.example."
    echo "⚠  Set your API key before running a build:"
    echo "   $MEMORY_DIR/.env → OPENROUTER_API_KEY=<your key>"
    echo "   Get a key at: https://openrouter.ai/keys"
else
    echo ".env already exists."
fi

echo ""
echo "Done. The memory system is ready."
