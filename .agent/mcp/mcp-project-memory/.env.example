# Port the server listens on (default: 8770)
PORT=8770

# OpenRouter API key for build pipeline
# OPENROUTER_API_KEY=

# LLM API endpoint (default: OpenRouter)
# MEMORY_BUILD_API_URL=https://openrouter.ai/api/v1/chat/completions

# Models for two-pass build (default: auto = best free model).
# Run `./mcp-project-memory models` to see available options.
#
# Recommended paid models (better quality):
#   google/gemini-2.5-flash-lite      (1M ctx, cheap — good for extraction)
#   google/gemini-2.5-flash           (1M ctx, reasoning — good for synthesis)
#   google/gemini-3.1-pro-preview     (1M ctx, best quality reasoning)
# MEMORY_EXTRACT_MODEL=auto
# MEMORY_EXTRACT_FALLBACK_MODEL=auto
# MEMORY_REASONING_MODEL=auto

# Batch settings
# MEMORY_BATCH_TOKEN_BUDGET=100000
# MEMORY_BATCH_MAX_COMMITS=20
# MEMORY_COMMIT_LIMIT=0

# Model constraints (minimum context length for auto-selection)
# MIN_CONTEXT_LENGTH=32000

# Path filtering (comma-separated globs to ignore)
# MEMORY_IGNORE_PATHS=.agent/mcp/mcp-project-memory/data/*

# Optional: max concurrent extraction workers (default 10).
# MEMORY_EXTRACT_CONCURRENCY=10

