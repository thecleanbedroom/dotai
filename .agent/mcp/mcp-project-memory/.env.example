# Port the server listens on (default: 8770)
PORT=8770

# OpenRouter API key for build pipeline
# OPENROUTER_API_KEY=

# Extraction model (default: nvidia/nemotron-3-super-120b-a12b:free)
# MEMORY_EXTRACT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Extraction fallback model (default: google/gemini-2.5-flash-lite)
# MEMORY_EXTRACT_FALLBACK_MODEL=google/gemini-2.5-flash-lite

# Synthesis/reasoning model (default: google/gemini-3.1-pro-preview)
# MEMORY_REASONING_MODEL=google/gemini-3.1-pro-preview

# Batch settings
# MEMORY_BATCH_TOKEN_BUDGET=100000
# MEMORY_BATCH_MAX_COMMITS=20
# MEMORY_COMMIT_LIMIT=0

# Path filtering (comma-separated globs to ignore)
# MEMORY_IGNORE_PATHS=.agent/memory/data/*
