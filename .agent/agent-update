#!/usr/bin/env bash
# Core update logic — fetched and run by AGENTS.sh
# Usage: update <target_dir>
set -euo pipefail

TARGET_DIR="${1:?Usage: update <target_dir>}"
POLICY_REPO_URL="git@github.com:thecleanbedroom/dotai.git"
REFERENCE="main"
SYNC_DIRS=".agent"

# ── Platform detection ───────────────────────────────────────
install_hint() {
    case "$(uname -s)" in
        Darwin) echo "  brew install $1" ;;
        Linux)
            if command -v apt >/dev/null 2>&1; then
                echo "  sudo apt install $1"
            elif command -v dnf >/dev/null 2>&1; then
                echo "  sudo dnf install $1"
            elif command -v pacman >/dev/null 2>&1; then
                echo "  sudo pacman -S $1"
            else
                echo "  Install '$1' using your package manager"
            fi
            ;;
        *)  echo "  Install '$1' for your platform" ;;
    esac
}

require_cmd() {
    local cmd="$1"
    local pkg="${2:-$1}"  # package name may differ from command
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: '$cmd' is required but not found." >&2
        echo "$(install_hint "$pkg")" >&2
        exit 1
    fi
}

# ── Dependency checks ────────────────────────────────────────
require_cmd git
require_cmd rsync
require_cmd go golang  # needed to build MCP servers

cat <<INFO
This script will clone the dotai policy repository and sync rules/config into:
  $TARGET_DIR

Existing policy files may be overwritten (except Git folders and project-local files).
Local-only files will be preserved. Review the diff after it completes.

To install skills, run the /add-skills workflow after syncing.
INFO

read -rp "Proceed with sync? [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    exit 0
fi

temp_dir="$(mktemp -d)"
trap 'rm -rf "$temp_dir"' EXIT

printf 'Fetching policy repo %s (%s)\n' "$POLICY_REPO_URL" "$REFERENCE"
git clone --depth 1 --branch "$REFERENCE" "$POLICY_REPO_URL" "$temp_dir/policy" >/dev/null 2>&1 || {
    echo "Error: git clone of policy repo failed" >&2
    exit 1
}

printf 'Syncing policy files to %s\n' "$TARGET_DIR"

# Sync only the directories we own — never touch project-local files
for dir in $SYNC_DIRS; do
    if [ -d "$temp_dir/policy/$dir" ]; then
        mkdir -p "$TARGET_DIR/$dir"
        rsync -av \
            --exclude 'skills' \
            --exclude 'mcp/*/data' \
            "$temp_dir/policy/$dir/" "$TARGET_DIR/$dir/"
    fi
done

# Sync root-level files we own
for file in AGENTS.sh AGENTS.md; do
    if [ -f "$temp_dir/policy/$file" ]; then
        cp "$temp_dir/policy/$file" "$TARGET_DIR/$file"
        printf '  %s\n' "$file"
    fi
done

# ── Build Go MCP servers for this platform ───────────────────
printf '\nBuilding MCP servers for %s/%s...\n' "$(uname -s | tr '[:upper:]' '[:lower:]')" "$(uname -m)"
for gomod in "$TARGET_DIR/.agent/mcp"/*/go.mod; do
    [ -f "$gomod" ] || continue
    dir="$(dirname "$gomod")"
    name="$(basename "$dir")"
    if [ -f "$dir/Makefile" ]; then
        printf '  Building %s...\n' "$name"
        make -C "$dir" build 2>&1 | sed 's/^/    /'
    else
        printf '  Building %s (go build)...\n' "$name"
        (cd "$dir" && go build -o "$name" ./cmd/"$name") 2>&1 | sed 's/^/    /'
    fi
done

echo ''
echo 'Policy files synchronized and MCP servers built.'
echo 'Run /add-skills to install project-specific skills.'
